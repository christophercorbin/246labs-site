# Amazon SES config for the contact form (set these in Amplify env vars).
SES_REGION=us-east-1
SES_SENDER=no-reply@246labs.cloud
SES_RECIPIENT=hello@246labs.cloud

# Cal.com booking link for the "Book a call" button (set in Amplify env vars).
# Inlined at build (NEXT_PUBLIC_*). When unset, the button is simply hidden.
NEXT_PUBLIC_BOOKING_URL=https://cal.com/246labs/intro
