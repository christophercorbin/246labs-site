# Amazon SES config for the contact form (set these in Amplify env vars).
SES_REGION=us-east-1
SES_SENDER=no-reply@246labs.cloud
SES_RECIPIENT=hello@246labs.cloud

# Optional override for the "Book a call" link. BookCall defaults to the
# 246Labs Cal.com page; set this only to point elsewhere (e.g. a self-hosted
# Cal.com). Inlined at build (NEXT_PUBLIC_*).
# NEXT_PUBLIC_BOOKING_URL=https://book.246labs.cloud/intro
